{
  "name": "@atlas/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts src/**/__tests__/**/*.test.ts",
    "test:retrieval": "node --import tsx --test src/retrieval/__tests__/**/*.test.ts src/evidence/__tests__/**/*.test.ts src/utils/__tests__/**/*.test.ts",
    "test:retrieval:regression": "tsx src/retrieval/__tests__/regression.brands.ts",
    "test:retrieval:regression:full": "REGRESSION_FULL=1 tsx src/retrieval/__tests__/regression.brands.ts"
  },
  "dependencies": {
    "@atlas/shared": "*",
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "robots-parser": "^3.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
